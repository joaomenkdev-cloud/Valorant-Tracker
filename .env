# ============================================================
# VCI Analytics — Backend Environment Variables
# ============================================================
# Copie este arquivo para .env e preencha com seus dados reais.
# NUNCA suba o arquivo .env para o Git!
# ============================================================

# Sua chave da HenrikDev API
# Obtenha em: https://api.henrikdev.xyz/dashboard/
# (entre no Discord deles primeiro: https://discord.gg/henrikdev)
HENRIK_API_KEY=HDEV-ebbc98eb-5b28-46b6-9f0f-47201c5d8a18

# Porta do servidor local
PORT=3001

# Ambiente (development | production)
NODE_ENV=development

# Origem permitida para CORS (seu frontend)
# Em desenvolvimento: http://localhost:5500 (Live Server do VSCode) ou file://
# Em produção: https://seudominio.com
ALLOWED_ORIGIN=*